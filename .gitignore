.gradle/
.gradle-user/
.m2/
build/
**/build/
.idea/
*.iml
web-console/node_modules/
web-console/dist/
web-console/.vite/

# 本地运行时产物 / 敏感数据 —— 永不入仓
JWT_SECRET.txt
FIRST_ADMIN_PASSWORD.txt

# Claude session 数据
.claude/

# 本地临时 / 调试日志
tmp/
*.log

# 部署产物 (jar / zip / 解压目录) —— 由 ./gradlew :agent-app:bootJar 生成,
# 单文件 70MB+,不入仓避免膨胀。deploy/ 目录(install.sh / nginx 配置)是入仓的。
dist/

# Agent 运行时 LLM 产出物 (artifacts/{runId}/...) —— 永不入仓
workspaces/**/artifacts/
agent-app/workspaces/**/artifacts/
